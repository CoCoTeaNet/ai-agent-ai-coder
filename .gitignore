# 项目根目录 gitignore 文件

# IDE 文件
.idea/
*.iml
*.ipr
*.iws

# 构建输出
target/
*.class
*.jar

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# 日志文件
*.log
logs/
log/

# 系统临时文件
tmp/
temp/

# 本地存储
.cache/
.storage/

# 上传的临时文件
agent_uploads/
